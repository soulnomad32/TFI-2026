Proceso Piramide_Centrada
    Definir n, i, j, k Como Entero
	
    Escribir "Ingrese la altura de la piramide:"
    Leer n
	
    Para i <- 1 Hasta n Hacer
        
        Para k <- 1 Hasta (n - i) Hacer
            Escribir Sin Saltar " "
        FinPara
		
        Para j <- 1 Hasta i Hacer
            Escribir Sin Saltar j, " "
        FinPara
		
        Escribir ""  
    FinPara
	
FinProceso